generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  DISMISSED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskSourceType {
  FLAG
  GAP
  SYSTEM
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  documents Document[]
}

model Document {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  originalFileName String
  mimeType         String
  storageKey       String
  createdAt        DateTime     @default(now())

  jobs        Job[]
  extractions Extraction[]
  tasks       Task[]
}

model Job {
  id         String    @id @default(uuid())
  documentId String
  document   Document  @relation(fields: [documentId], references: [id])

  status     JobStatus
  attempts   Int       @default(0)
  error      String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  startedAt  DateTime?
  finishedAt DateTime?
  lockedAt   DateTime?
}

model Extraction {
  id             String    @id @default(uuid())
  documentId     String
  document       Document  @relation(fields: [documentId], references: [id])

  text           String
  textStorageKey String?
  meta           Json?
  structured     Json?
  analysisError  String?
  redFlags       Json?

  createdAt      DateTime  @default(now())
}

model Task {
  id                String          @id @default(uuid())
  documentId        String
  document          Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  taskKey           String
  title             String
  description       String
  status            TaskStatus      @default(TODO)
  priority          TaskPriority    @default(MEDIUM)
  sourceType        TaskSourceType
  sourceRef         String?
  relatedPlanIndexes Int[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([documentId, taskKey])
}


