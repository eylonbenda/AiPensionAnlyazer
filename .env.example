# Use port 5433 when using infra/docker-compose (Postgres is mapped 5433:5432)
DATABASE_URL=postgresql://app:app@localhost:5433/pension_ai?schema=public
REDIS_URL=redis://localhost:6379

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=app
MINIO_SECRET_KEY=appappapp
MINIO_BUCKET=pension-ai-analyzer

API_PORT=3000
NODE_ENV=development

# JWT signing secret for auth (required for login/register and protected endpoints)
JWT_SECRET=your-secret-at-least-32-chars-long

# AI extraction: set AI_PROVIDER=openai and OPENAI_API_KEY for real extraction; omit key to use stub.
AI_PROVIDER=openai
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.0
AI_MAX_TOKENS=2048
AI_TIMEOUT_MS=60000

